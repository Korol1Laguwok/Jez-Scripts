-- Функция перевода и КОПИРОВАНИЯ
local function copyTranslatedMessage()
    local text = MyTextBox.Text
    if text == "" then return end

    local cleanedText = text:gsub("(%a)%1%1+", "%1%1") 
    
    -- ВАЖНО: sl=ru (с русского) tl=..targetLang (на выбранный язык)
    local url = "https://translate.googleapis.com/translate_a/single?client=gtx&sl=ru&tl="..targetLang.."&dt=t&q=" .. HttpService:UrlEncode(cleanedText)
    
    local success, result = pcall(function()
        return game:HttpGet(url)
    end)
    
    if success then
        local decoded = HttpService:JSONDecode(result)
        if decoded and decoded[1] and decoded[1][1] and decoded[1][1][1] then
            local translatedText = decoded[1][1][1]
            
            -- Мы убрали проверку (trans ~= text), теперь копируется ВСЁ
            setclipboard(translatedText)
            
            -- Эффект успеха
            local oldText = SendBtn.Text
            SendBtn.Text = "СКОПИРОВАНО!"
            SendBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
            
            task.delay(1.5, function()
                SendBtn.Text = oldText
                SendBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            end)
            
            MyTextBox.Text = "" 
        end
    end
end

-- Привязываем новую функцию к кнопке
SendBtn.MouseButton1Click:Connect(copyTranslatedMessage)
MyTextBox.FocusLost:Connect(function(ep) if ep then copyTranslatedMessage() end end)


-- 3. ЛОГИКА
local function translate(text)
    -- 1. Очистка от лишних букв (heeello -> heello)
    local cleanedText = text:gsub("(%a)%1%1+", "%1%1") 
    
    -- 2. Ссылка для Google API
    local url = "https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl=ru&dt=t&q=" .. HttpService:UrlEncode(cleanedText)
    
    local success, result = pcall(function() return game:HttpGet(url) end)
    
    if success and result:find('[%[%]]') then
        -- Google возвращает JSON. Нам нужно достать первую строку из первой таблицы.
        local decoded = HttpService:JSONDecode(result)
        
        -- У Google структура такая: decoded[1][1][1]
        if decoded and decoded[1] and decoded[1][1] and decoded[1][1][1] then
            local trans = decoded[1][1][1]
            
            -- Возвращаем перевод, только если он реально изменил слово
            return (trans:lower() ~= text:lower()) and trans or nil
        end
    end
    return nil
end

