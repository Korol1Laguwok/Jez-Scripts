-- 1. СЛОВАРЬ ДЛЯ УЛУЧШЕНИЯ СМЫСЛА (исправляет сленг перед переводом)
local slangMap = {
    ["im"] = "I am",
    ["u"] = "you",
    ["r"] = "are",
    ["n"] = "and",
    ["wanna"] = "want to",
    ["gonna"] = "going to",
    ["lmao"] = "funny",
}

local function fixSlang(text)
    local words = text:lower():split(" ")
    for i, word in ipairs(words) do
        if slangMap[word] then
            words[i] = slangMap[word]
        end
    end
    return table.concat(words, " ")
end

