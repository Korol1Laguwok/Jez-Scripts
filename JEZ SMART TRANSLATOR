    ChatLog.CanvasSize = UDim2.new(0, 0, 0, LogList.AbsoluteContentSize.Y)
    ChatLog.CanvasPosition = Vector2.new(0, ChatLog.CanvasSize.Y.Offset)
end


local function onChatted(player, message)
    if player == localPlayer then return end
    local translated = translate(message)
    if translated then createMessage(player.Name, translated) end
end

Players.PlayerAdded:Connect(function(p) p.Chatted:Connect(function(m) onChatted(p, m) end) end)
for _, p in pairs(Players:GetPlayers()) do p.Chatted:Connect(function(m) onChatted(p, m) end) end
