    avatarImg.BorderSizePixel = 0
    Instance.new("UICorner", avatarImg).CornerRadius = UDim.new(1, 0) -- Делаем круглой
    
    -- Пытаемся получить фото игрока
    local s, e = pcall(function()
        local sender = Players:FindFirstChild(user)
        if sender then
            -- HeadShot - лицо крупным планом, Size48x48 - оптимальный размер
            local content, isReady = Players:GetUserThumbnailAsync(sender.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
            avatarImg.Image = content
        else
            -- Заглушка, если игрок уже вышел
            avatarImg.Image = "rbxassetid://15132410427" 
        end
    end)
    -- Если Roblox API заглючил, ставим пустую картинку, чтобы скрипт не упал
    if not s then avatarImg.Image = "" end 


    -- === НИКНЕЙМ ===
