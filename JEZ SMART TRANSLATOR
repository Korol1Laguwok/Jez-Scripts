    hLayout.VerticalAlignment = Enum.VerticalAlignment.Center
    hLayout.Padding = UDim.new(0, 8) -- Отступ между фото, ником и текстом
    Instance.new("UIPadding", msgFrame).PaddingLeft = UDim.new(0, 5)

    -- === БЛОК АВАТАРКИ ===
