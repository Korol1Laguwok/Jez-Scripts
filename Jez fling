            UserLabel.Size = UDim2.new(1, -65, 0, 20)
            UserLabel.Position = UDim2.new(0, 60, 0, 28)
            UserLabel.BackgroundTransparency = 1
            UserLabel.Text = "@" .. p.Name
            UserLabel.TextColor3 = Color3.fromRGB(160, 160, 160) -- Неяркий серый
            UserLabel.Font = Enum.Font.SourceSans
            UserLabel.TextSize = 14
            UserLabel.TextXAlignment = Enum.TextXAlignment.Left

            -- ОБВОДКА ПРИ НАВЕДЕНИИ
            local bStroke = Instance.new("UIStroke", Btn)
            bStroke.Color = Color3.fromRGB(0, 160, 0)
            bStroke.Thickness = 2
