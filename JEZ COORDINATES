-- === УЛЬТРА-БЫСТРАЯ ФУНКЦИЯ ПУТИ ===
local PathfindingService = game:GetService("PathfindingService")

local function createVisualWaypoint(position, name)
    local folder = workspace:FindFirstChild("JezWaypoints") or Instance.new("Folder", workspace)
    folder.Name = "JezWaypoints"
    
    local part = Instance.new("Part")
    part.Name = name .. "_Target"
    part.Position = position + Vector3.new(0, 0.5, 0)
    part.Size = Vector3.new(2, 2, 2)
    part.Shape = Enum.PartType.Ball
    part.Material = Enum.Material.Neon
    part.Color = Color3.fromRGB(0, 255, 100)
    part.Anchored = true
    part.CanCollide = false
    part.Parent = folder
    
    local billboard = Instance.new("BillboardGui", part)
    billboard.Size = UDim2.new(0, 100, 0, 30)
    billboard.AlwaysOnTop = true
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    local label = Instance.new("TextLabel", billboard)
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = name
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 14

    local routeFolder = Instance.new("Folder", part)
    routeFolder.Name = "Route"

    -- Настройки быстрого пути
    local path = PathfindingService:CreatePath({
        AgentRadius = 2,
        AgentHeight = 5,
        AgentCanJump = true,
        WaypointSpacing = 8, -- Еще больше расстояние (минимум объектов)
    })

    local lastPos = Vector3.new(0,0,0)

    local function updatePath()
        if not part or not part.Parent then return end
        
        local character = localPlayer.Character
        local hrp = character and character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        -- Пересчитываем только если отошли на 10 метров (огромная экономия мощи)
        if (hrp.Position - lastPos).Magnitude < 10 then return end
        lastPos = hrp.Position

        local success, _ = pcall(function()
            path:ComputeAsync(hrp.Position, position)
        end)

        if success and path.Status == Enum.PathStatus.Success then
            routeFolder:ClearAllChildren()
            local waypoints = path:GetWaypoints()
            
            -- Отрисовка только ближайших 15 точек (чтобы не грузить карту)
            local maxWaypoints = math.min(#waypoints, 15) 
            
            for i = 1, maxWaypoints - 1 do
                local p1 = waypoints[i].Position
                local p2 = waypoints[i+1].Position
                
                -- Используем очень тонкие детали-линии
                local line = Instance.new("Part")
                line.Size = Vector3.new(0.2, 0.2, (p1 - p2).Magnitude)
                line.CFrame = CFrame.new(p1:Lerp(p2, 0.5), p2)
                line.Anchored = true
                line.CanCollide = false
                line.Material = Enum.Material.Neon
                line.Color = Color3.fromRGB(0, 255, 150)
                line.Transparency = 0.7
                line.Parent = routeFolder
            end
        end
    end

    -- Сверхбыстрый цикл проверки
    task.spawn(function()
        while part and part.Parent do
            updatePath()
            task.wait(0.5) -- Проверяем часто, но за счет лимита в 10 метров лагать не будет
        end
    end)
    
    return part
end

