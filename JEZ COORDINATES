local function getPointedCoordinates()
    local mousePos = UserInputService:GetMouseLocation()
    local unitRay = camera:ViewportPointToRay(mousePos.X, mousePos.Y)
    local result = workspace:Raycast(unitRay.Origin, unitRay.Direction * 5000)
    if result then
        local pos = result.Position
        local formatted = string.format("%.1f, %.1f, %.1f", pos.X, pos.Y, pos.Z)
        if setclipboard then setclipboard(formatted) end
        return formatted
    end
    return nil
end

