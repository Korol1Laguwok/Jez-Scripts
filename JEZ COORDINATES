-- ПЕРЕМЕННЫЕ ДЛЯ ЛОГИКИ
local isAuto = false

-- Функция телепорта
local function doTeleport()
    local text = TPInput.Text
    local coords = {}
    for num in string.gmatch(text:gsub(",", " "), "[%d%.%-]+") do
        table.insert(coords, tonumber(num))
    end
    if #coords >= 3 then
        local targetPos = Vector3.new(coords[1], coords[2], coords[3])
        local char = game.Players.LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.CFrame = CFrame.new(targetPos + Vector3.new(0, 3, 0))
            return true
        end
    end
    return false
end

-- Логика одиночного ТП
TPBtn.MouseButton1Click:Connect(function()
    if doTeleport() then
        TPBtn.Text = "OK!"
        task.delay(1, function() TPBtn.Text = "TP" end)
    else
        TPBtn.Text = "?"
        task.delay(1, function() TPBtn.Text = "TP" end)
    end
end)

-- Логика AUTO-TP
AutoBtn.MouseButton1Click:Connect(function()
    isAuto = not isAuto
    if isAuto then
        AutoBtn.Text = "AUTO: ON"
        AutoBtn.BackgroundColor3 = Color3.fromRGB(255, 80, 80) -- Красный при работе
        
        -- Запускаем цикл в отдельном потоке
        task.spawn(function()
            while isAuto do
                local waitTime = tonumber(TimeInput.Text) or 1
                doTeleport()
                task.wait(waitTime)
            end
        end)
    else
        AutoBtn.Text = "AUTO: OFF"
        AutoBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    end
end)
