-- [[ ПРОВЕРКА ВИДИМОСТИ ]] --
local function isVisible(targetPart)
    local character = LocalPlayer.Character
    if not character then return false end
    
    local raycastParams = RaycastParams.new()
    -- Добавляем и твоего персонажа, и GUI в список исключений
    raycastParams.FilterDescendantsInstances = {character, ScreenGui}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude

    local raycastResult = workspace:Raycast(Camera.CFrame.Position, (targetPart.Position - Camera.CFrame.Position), raycastParams)
    
    -- Если луч ни обо что не ударился или попал в часть тела цели — значит врага видно
    if not raycastResult or raycastResult.Instance:IsDescendantOf(targetPart.Parent) then
        return true
    end
    return false
end

-- [[ ПОИСК ЦЕЛИ ]] --
local function getClosestPlayer()
    local closest = nil
    local shortestDistance = math.huge
    local mousePos = UserInputService:GetMouseLocation()

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
            local head = p.Character.Head
            local humanoid = p.Character:FindFirstChild("Humanoid")
            
            if humanoid and humanoid.Health > 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(head.Position)
                
                if onScreen then
                    if isVisible(head) then -- Теперь проверяем видимость именно головы
                        local distance = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                        if distance <= FOV_Radius and distance < shortestDistance then
                            closest = head -- Возвращаем голову как цель
                            shortestDistance = distance
                        end
                    end
                end
            end
        end
    end
    return closest
end

local function createESP(player)
    local lines = {
        T = Drawing.new("Line"), B = Drawing.new("Line"), 
        L = Drawing.new("Line"), R = Drawing.new("Line")
    }

    local function update()
        local connection
        connection = RunService.RenderStepped:Connect(function()
            -- Если игрок вышел или меню удалено — убираем линии
            if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") or not ScreenGui.Parent then
                for _, v in pairs(lines) do v.Visible = false end
                if not player.Parent or not ScreenGui.Parent then connection:Disconnect() end
                return
            end

            local root = player.Character.HumanoidRootPart
            local pos, onScreen = Camera:WorldToViewportPoint(root.Position)

            if onScreen and ESP_Enabled then
                local sizeY = (Camera:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0)).Y - Camera:WorldToViewportPoint(root.Position + Vector3.new(0, -3.5, 0)).Y)
                local sizeX = sizeY / 1.5
                local x, y = pos.X, pos.Y

               -- Внутри функции update() в createESP
local function setLine(line, p1, p2)
    line.Visible = true
    line.From = p1
    line.To = p2
    line.Color = ESP_Color
    line.Thickness = 1.5 -- Сделаем линии ESP чуть четче
    line.Transparency = 0.8 -- Сделаем их слегка мягче для глаза
end

-- Центрирование рамки по телу
setLine(lines.T, Vector2.new(x - sizeX/2, y - sizeY/2), Vector2.new(x + sizeX/2, y - sizeY/2)) -- Верх
setLine(lines.B, Vector2.new(x - sizeX/2, y + sizeY/2), Vector2.new(x + sizeX/2, y + sizeY/2)) -- Низ
setLine(lines.L, Vector2.new(x - sizeX/2, y - sizeY/2), Vector2.new(x - sizeX/2, y + sizeY/2)) -- Лево
setLine(lines.R, Vector2.new(x + sizeX/2, y - sizeY/2), Vector2.new(x + sizeX/2, y + sizeY/2)) -- Право
            else
                for _, v in pairs(lines) do v.Visible = false end
            end
        end)
    end
    coroutine.wrap(update)()
end

