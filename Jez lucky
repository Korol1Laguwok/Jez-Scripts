-- ЛОГИКА
local isStopped = false
local isRunning = false

-- Закрытие
CloseBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

-- Очистка блоков в мире
ClearBtn.MouseButton1Click:Connect(function()
    local count = 0
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (obj.Name:find("Block") or obj.Name:find("Lucky")) then
            obj:Destroy()
            count = count + 1
        end
    end
    ClearBtn.Text = "УДАЛЕНО: " .. count
    task.wait(1.5)
    ClearBtn.Text = "ОЧИСТИТЬ ВСЁ"
end)

-- Спавн блоков
StartBtn.MouseButton1Click:Connect(function()
    if isRunning then return end
    local total = tonumber(AmountInput.Text)
    if not total or total <= 0 then return end
    
    isRunning = true
    isStopped = false
    StopBtn.Visible = true
    
    task.spawn(function()
        for i = 1, total do
            if isStopped then break end
            
            local eventName = BlockEvents[i % #BlockEvents + 1]
            local remote = ReplicatedStorage:FindFirstChild(eventName)
            
            if remote then
                remote:FireServer()
                StartBtn.Text = i .. " / " .. total
            end
            
            -- Задержка каждые 20 блоков, чтобы не кикнуло за спам
            if i % 20 == 0 then
                task.wait(math.random(5, 10) / 100)
            end
        end
        
        StartBtn.Text = "ГОТОВО!"
        task.wait(2)
        StartBtn.Text = "ЗАПУСТИТЬ"
        StopBtn.Visible = false
        isRunning = false
    end)
end)

StopBtn.MouseButton1Click:Connect(function()
    isStopped = true
end)
