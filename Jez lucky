-- Функция для вывода "достижения"
local function ShowAchievement(title, text)
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = title;
        Text = text;
        Icon = "rbxassetid://6023426926"; -- Иконка щита/галочки
        Duration = 5; -- Сколько секунд будет висеть
    })
end

-- Вызываем уведомление сразу при запуске скрипта
