Instance.new("UICorner", StopBtn).CornerRadius = UDim.new(0, 8)

-- ЛОГИКА
CloseBtn.MouseButton1Click:Connect(function() LuckyGui:Destroy() end)

local stopRequested = false
local isSpawning = false

ClearBtn.MouseButton1Click:Connect(function()
    local count = 0
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (obj.Name:find("Block") or obj.Name:find("Lucky")) then
            obj:Destroy()
            count = count + 1
        end
    end
    ClearBtn.Text = "УДАЛЕНО: " .. count
    task.wait(1.5)
    ClearBtn.Text = "ОЧИСТИТЬ ВСЁ"
end)

SpawnBtn.MouseButton1Click:Connect(function()
    if isSpawning then return end
    local count = tonumber(AmountInput.Text)
    if not count or count <= 0 then return end
    isSpawning = true
    stopRequested = false
    StopBtn.Visible = true
    task.spawn(function()
        for i = 1, count do
            if stopRequested then break end
            local blockIndex = (i % #blockNames) + 1
            local Remote = ReplicatedStorage:FindFirstChild(blockNames[blockIndex])
            if Remote then
                Remote:FireServer()
                SpawnBtn.Text = i .. " / " .. count
            end
            if i % 20 == 0 then task.wait(math.random(5, 10)/100) end
        end
        SpawnBtn.Text = "ГОТОВО!"
        task.wait(2)
        SpawnBtn.Text = "ЗАПУСТИТЬ"
        StopBtn.Visible = false
        isSpawning = false
    end)
end)

StopBtn.MouseButton1Click:Connect(function() stopRequested = true end)

pcall(function() script.Parent = nil end)
