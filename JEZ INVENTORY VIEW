local function updatePlayers()
    for _, child in pairs(PlayerList:GetChildren()) do 
        if child:IsA("TextButton") then child:Destroy() end 
    end
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= localPlayer then
            local btn = Instance.new("TextButton", PlayerList)
            btn.Size = UDim2.new(1, -5, 0, 40)
            btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
            btn.Text = p.DisplayName
            btn.TextColor3 = Color3.new(1, 1, 1)
            btn.Font = Enum.Font.SourceSansBold
            btn.TextSize = 14
            Instance.new("UICorner", btn)
            
            btn.MouseButton1Click:Connect(function() 
                showInventory(p) 
                Title.Text = "VIEWING: " .. p.Name:upper()
            end)
        end
    end
end

-- === ЛОГИКА АВТО-ОБНОВЛЕНИЯ ===


game.Players.PlayerAdded:Connect(updatePlayers)
game.Players.PlayerRemoving:Connect(updatePlayers)


task.spawn(function()
    while task.wait(2) do
        
        local currentText = Title.Text
        if currentText:find("VIEWING: ") then
            local targetName = currentText:gsub("VIEWING: ", ""):lower()
            
            
            for _, p in pairs(game.Players:GetPlayers()) do
                if p.Name:upper() == targetName:upper() then
                    showInventory(p) 
                    break
                end
            end
        end
    end
end)

updatePlayers()
