-- === ФУНКЦИЯ ДЛЯ 2D-ИКОНОК (ИСПРАВЛЕНО) ===
local function createStyledIcon(tool, parent)
    local iconFrame = Instance.new("Frame", parent)
    iconFrame.Size = UDim2.new(0, 50, 0, 50)
    iconFrame.Position = UDim2.new(0, 5, 0.5, -25)
    iconFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    iconFrame.BorderSizePixel = 0
    Instance.new("UICorner", iconFrame).CornerRadius = UDim.new(0, 8)

    local itemIcon = Instance.new("ImageLabel", iconFrame)
    itemIcon.Size = UDim2.new(1, -8, 1, -8)
    itemIcon.Position = UDim2.new(0.5, 0, 0.5, 0)
    itemIcon.AnchorPoint = Vector2.new(0.5, 0.5)
    itemIcon.BackgroundTransparency = 1
    
    -- Логика отображения: сначала ищем текстуру, если нет - генерируем иконку модели
    if tool:IsA("Tool") then
        if tool.TextureId ~= "" then
            itemIcon.Image = tool.TextureId
        else
            -- Если TextureId пустой, используем rbxthumb (генерирует иконку из модели)
            itemIcon.Image = "rbxthumb://type=Asset&id=" .. tool.ToolTip .. "&w=150&h=150"
            
            -- Если и rbxthumb не помог, ставим стандартную иконку Roblox
            if itemIcon.Image == "" then
                itemIcon.Image = "rbxassetid://125431355"
            end
        end
    end

    local countLabel = Instance.new("TextLabel", iconFrame)
    countLabel.Size = UDim2.new(0, 20, 0, 20)
    countLabel.Position = UDim2.new(0, 3, 0, 0)
    countLabel.BackgroundTransparency = 1
    countLabel.Text = ""
    countLabel.TextColor3 = Color3.new(1, 1, 1)
    countLabel.Font = Enum.Font.SourceSansBold
    countLabel.TextSize = 13
    countLabel.TextXAlignment = Enum.TextXAlignment.Left
    
    local stroke = Instance.new("UIStroke", countLabel)
    stroke.Thickness = 1
    stroke.Color = Color3.fromRGB(0, 0, 0)
end

local function showInventory(targetPlayer)
    for _, child in pairs(ItemDisplay:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    local foundTools = {}
    if targetPlayer:FindFirstChild("Backpack") then
        for _, t in pairs(targetPlayer.Backpack:GetChildren()) do if t:IsA("Tool") then table.insert(foundTools, t) end end
    end
    if targetPlayer.Character then
        for _, t in pairs(targetPlayer.Character:GetChildren()) do if t:IsA("Tool") then table.insert(foundTools, t) end end
    end

    for _, tool in pairs(foundTools) do
        local itemFrame = Instance.new("Frame", ItemDisplay)
        itemFrame.Size = UDim2.new(1, -10, 0, 60)
        itemFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        Instance.new("UICorner", itemFrame)

        createStyledIcon(tool, itemFrame)

        local label = Instance.new("TextLabel", itemFrame)
        label.Size = UDim2.new(1, -65, 1, 0)
        label.Position = UDim2.new(0, 65, 0, 0)
        label.BackgroundTransparency = 1
        label.Text = tool.Name
        label.TextColor3 = Color3.new(1, 1, 1)
        label.Font = Enum.Font.SourceSansBold
        label.TextSize = 13
        label.TextXAlignment = Enum.TextXAlignment.Left
    end
end

